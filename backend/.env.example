# ---- Survival Finnish backend configuration ------------------------------
# Copy this file to `.env` and fill in your ElevenLabs API key.
# Get a key at https://elevenlabs.io/ (Profile -> API Keys).

# Required for live speech synthesis:
ELEVENLABS_API_KEY=

# Voice + model (defaults are fine for Finnish):
#   eleven_multilingual_v2 supports Finnish.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# Server:
PORT=8787
CACHE_DIR=./cache
# Restrict which site may call the API in production, e.g.
#   CORS_ORIGIN=https://ra-nayreed.github.io
CORS_ORIGIN=*
